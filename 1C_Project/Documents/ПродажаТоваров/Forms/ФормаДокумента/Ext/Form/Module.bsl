&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
    
    ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
    
    Если ТекущаяСтрока.Номенклатура = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    Цена = ПолучитьЦену(ТекущаяСтрока.Номенклатура);
    ТекущаяСтрока.Цена = Цена;
    
    Если ТекущаяСтрока.Количество = 0 Или ТекущаяСтрока.Количество = Неопределено Тогда
        ТекущаяСтрока.Количество = 1;
    КонецЕсли;
    
    // Считаем сумму через ОБЩИЙ МОДУЛЬ
    РасчетСумм.РассчитатьСуммуВСтроке(ТекущаяСтрока);
    
КонецПроцедуры

&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
    
    ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
    РасчетСумм.РассчитатьСуммуВСтроке(ТекущаяСтрока);
    
КонецПроцедуры

&НаСервере
Функция ПолучитьЦену(НоменклатураСсылка)
    
    Ключ = Новый Структура("Номенклатура", НоменклатураСсылка);
    
    ЗаписьЦены = РегистрыСведений.ЦеныНоменклатуры.Получить(
        Ключ,
        ТекущаяДата()
    );
    
    Если ЗаписьЦены <> Неопределено Тогда
        Возврат ЗаписьЦены.Цена;
    Иначе
        Возврат 0;
    КонецЕсли;
    
КонецФункции